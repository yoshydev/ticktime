{
	"name": "@yoshydev/ticktime",
	"version": "0.1.0",
	"description": "チケット別の作業時間を管理するローカルツール（タイマー計測・日次〆処理・報告フォームURL生成）",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yoshydev/ticktime.git"
	},
	"type": "module",
	"bin": {
		"ticktime": "bin/ticktime.js"
	},
	"files": [
		"build",
		"!build/**/*.map",
		"bin",
		"!bin/*.test.js"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite dev",
		"demo": "node scripts/demo-seed.ts && TICKTIME_DB=data/demo.db vite dev --port 5174",
		"demo:fresh": "node scripts/demo-seed.ts --fresh && TICKTIME_DB=data/demo.db vite dev --port 5174",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node bin/ticktime.js",
		"prepack": "npm run build",
		"prepare": "(svelte-kit sync || echo '') && (git config core.hooksPath .githooks || echo '')",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run"
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"better-sqlite3": "^12.11.1"
	}
}
